{
    "name": "max-use",
    "version": "0.0.2",
    "description": "Biblioteca de Funções e Composables Vue",
    "main": "./dist/index.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.js"
        },
        "./dist/style.css": "./dist/style.css"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "dev:playground": "vite --config playground/vite.config.ts",
        "prebuild": "npx tsx src/scripts/generateResolver.ts",
        "build": "vue-tsc && vite build",
        "build:uno": "node scripts/build-uno.mjs",
        "preview": "vite preview",
        "type-check": "vue-tsc --noEmit",
        "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1",
        "@vueuse/integrations": "^14.2.1",
        "js-brasil": "^2.8.0",
        "ulid": "^3.0.2"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^22.10.5",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vue/eslint-config-typescript": "^14.1.3",
        "@vue/tsconfig": "^0.7.0",
        "ajv": "^8.18.0",
        "eslint": "^9.39.4",
        "eslint-plugin-vue": "^9.33.0",
        "sass-embedded": "^1.99.0",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.59.0",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^32.0.0",
        "vite": "^8.0.9",
        "vite-plugin-css-injected-by-js": "^5.0.1",
        "vite-plugin-dts": "^4.5.4",
        "vue": "^3.5.13",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^2.1.10"
    },
    "keywords": [
        "vue",
        "vue3",
        "typescript"
    ],
    "author": "Johnattas Santana",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/johnattas/MaxUse.git"
    },
    "peerDependencies": {
        "vue": "^3.5.33"
    }
}
